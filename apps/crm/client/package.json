{
  "name": "@apps/crm-client",
  "version": "1.0.0",
  "author": "Simon Stranks <sstranks0@gmail.com> <https://github.com/SStranks>",
  "license": "ISC",
  "type": "module",
  "main": "./src/index.tsx",
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "last 2 versions"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "scripts": {
    "clean": "rm -rf dist",
    "compile": "tsc -b tsconfig.src.json --noEmit",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts --watch",
    "tsr": "tsr generate",
    "tsr:watch": "tsr watch",
    "start": "dotenvx run -f ./.env.dev.client -- webpack serve --disable-interpret --config ./webpack/webpack.dev.ts",
    "build": "dotenvx run -f ./.env.prod.client -- webpack --config ./webpack/webpack.prod.js",
    "build:watch": "dotenvx run -f ./.env.prod.client -- webpack --config ./webpack.dev.js --watch",
    "build:serve": "http-server ./dist --brotli",
    "build:stats": "bundle-stats --html --json -d ./webpack/stats ./dist/stats/build-stats.json",
    "build:stats:serve": "http-server ./webpack/stats -o bundle-stats.html",
    "vitest:all": "vitest run --mode test --config ./vitest.config.ts",
    "vitest:unit": "vitest run --mode test --config ./vitest.config.ts --project=unit",
    "vitest:storybook": "vitest run --mode test --config ./vitest.config.ts --project=storybook",
    "vitest:watch": "vitest watch --mode test --config ./vitest.config.ts",
    "vitest:list": "vitest list --mode test --filesOnly --config ./vitest.config.ts",
    "cypress:open": "cypress open",
    "cypress:ui": "start-server-and-test start http://localhost:3000 cypress:e2e",
    "cypress:e2e": "cypress run",
    "cypress:component": "cypress run --component",
    "storybook": "storybook dev -p 6006 --no-open",
    "storybook:build": "storybook build --no-open",
    "sass:types": "typed-scss-modules src --ignore \"**/assets/sass/**/*.scss\" --aliasPrefixes.@Sass \"src/assets/sass\" --exportType default --nameFormat none",
    "sassdoc:build": "sassdoc ./src --dest ./.sassdoc",
    "sassdoc:serve": "http-server ./.sassdoc",
    "dotenv:lint": "docker run --rm -v \"$(pwd)\":/app -w /app dotenvlinter/dotenv-linter:4.0.0 check -r .env* -e .env*.enc"
  },
  "dependencies": {
    "@apollo/client": "^4.2.0",
    "@atlaskit/pragmatic-drag-and-drop": "^1.7.7",
    "@atlaskit/pragmatic-drag-and-drop-hitbox": "^1.1.0",
