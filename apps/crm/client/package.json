    "@tanstack/react-table": "^8.21.3",
    "@uiw/react-md-editor": "^4.0.8",
    "@zxcvbn-ts/core": "^4.1.0",
    "@zxcvbn-ts/language-common": "^4.1.0",
    "@zxcvbn-ts/language-en": "^4.1.0",
    "axios": "^1.13.5",
    "clsx": "^2.1.1",
    "graphql": "^16.12.0",
