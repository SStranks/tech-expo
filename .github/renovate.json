{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "docker:pinDigests"],
  "enabledManagers": ["docker-compose", "dockerfile", "github-actions", "nvm", "npm"],
  "dependencyDashboard": true,
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)(Dockerfile|Dockerfile\\..*)$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?)\\s+ARG .*?_VERSION=(?<currentValue>[^\\s]+)"
      ]
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["npm"],
      "enabled": false
    },
    {
      "matchManagers": ["npm"],
      "matchPackageNames": ["@playwright/test"],
      "enabled": true
    },
    {
      "groupName": "Docker-compose images",
      "matchManagers": ["docker-compose"],
      "matchPackageNames": ["!node"],
      "minimumReleaseAge": "5 days"
    },
    {
      "groupName": "Dockerfile images",
      "matchManagers": ["dockerfile"],
      "matchUpdateTypes": ["minor", "patch"],
      "minimumReleaseAge": "5 days"
    },
    {
      "groupName": "GitHub Actions",
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["!mcr.microsoft.com/playwright"]
    },
    {
      "groupName": "Playwright",
      "matchPackageNames": ["@playwright/test", "mcr.microsoft.com/playwright"]
    },
    {
      "groupName": "Node.js version",
      "matchManagers": ["nvm", "github-actions", "docker-compose", "dockerfile"],
      "matchPackageNames": ["node", "actions/node-versions"],
      "matchDepNames": ["node", "actions/node-versions"],
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "description": "Disable Node major updates",
      "matchPackageNames": ["node", "actions/node-versions"],
      "matchDepNames": ["node", "actions/node-versions"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    }
  ]
}
