root = true

[*]
# Non-configurable Prettier behaviors
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

# Configurable Prettier behaviors
end_of_line = lf
indent_style = space
indent_size = 2

[*.{js,ts,jsx,tsx}]
indent_size = 2

[*.{json,jsonc,json5,yaml,yml,toml}]
indent_size = 2

[*.{css,scss,sass}]
indent_size = 2

[*.{html,ejs}]
indent_size = 2
trim_trailing_whitespace = true

[*.{md,mdx}]
indent_size = 2
trim_trailing_whitespace = true

[*.sh]
indent_size = 2
indent_style = space

[*.csv]
trim_trailing_whitespace = false
indent_size = 0

[{.env,.env.*}]
trim_trailing_whitespace = false
indent_size = 0

[*.{key,pem,crt,csr,srl,ext,cnf}]
trim_trailing_whitespace = false
insert_final_newline = false

[{Dockerfile,Dockerfile.*}]
indent_size = 2

[{.gitignore,.dockerignore,.prettierignore}]
trim_trailing_whitespace = false

[Makefile]
indent_size = 2
indent_style = tab
